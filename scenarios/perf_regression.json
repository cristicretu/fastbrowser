{
  "name": "Performance Regression Check",
  "description": "Scroll through document and verify no perf regressions — DOM nodes < 5000, no longtasks during scroll",
  "checkpoint": "doc-loaded",
  "steps": [
    { "action": "eval", "js": "document.querySelectorAll('*').length" },
    { "action": "scroll", "deltaY": 1000 },
    { "action": "wait", "ms": 100 },
    { "action": "scroll", "deltaY": 1000 },
    { "action": "wait", "ms": 100 },
    { "action": "scroll", "deltaY": 1000 },
    { "action": "wait", "ms": 100 },
    { "action": "scroll", "deltaY": -3000 },
    { "action": "wait", "ms": 100 },
    { "action": "eval", "js": "document.querySelectorAll('*').length" },
    { "action": "assertVisible", "selector": "[data-testid='editor'], .editor, [contenteditable], main" }
  ]
}
